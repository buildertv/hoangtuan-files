<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= file.name %> | BuilderTV</title>
    <meta name="description" content="<%= file.name %> - Tải ngay">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        /* RESET & BASE */
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: #0f172a; /* Màu nền từ CSS của bạn */
            color: #f1f5f9;
            font-family: 'Inter', 'Segoe UI', sans-serif;
            line-height: 1.6;
        }

        /* HEADER FIXED */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            background: #020617; /* Đậm hơn nền */
            border-bottom: 1px solid #1e293b;
            z-index: 1000;
        }

        .header-inner {
            max-width: 900px;
            margin: auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 16px;
        }

        .logo {
            font-weight: 800;
            font-size: 1.1rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            color: #fff;
            text-decoration: none;
        }

        .nav { display: flex; gap: 20px; }
        .nav a {
            color: #94a3b8;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: 0.2s;
        }
        .nav a:hover { color: #fff; }

        /* CONTAINER */
        .container {
            max-width: 800px;
            margin: auto;
            padding: 100px 16px 40px; /* Offset cho fixed header */
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: #94a3b8;
            text-decoration: none;
            font-size: 14px;
            margin-bottom: 24px;
            cursor: pointer;
            transition: 0.2s;
        }
        .back-link:hover { color: #38bdf8; }

        /* MAIN CARD */
        .card {
            background: #1e293b; /* Màu card từ CSS của bạn */
            padding: 32px;
            border-radius: 16px;
            border: 1px solid #334155;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3);
        }

        h1 {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 24px;
            color: #fff;
            line-height: 1.3;
        }

        /* BUTTONS */
        .btn-group {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 14px 24px;
            border-radius: 12px;
            font-weight: 600;
            text-decoration: none;
            font-size: 1rem;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
        }

        /* Nút Download dùng Gradient xanh từ CSS của bạn */
        .btn-download {
            background: linear-gradient(135deg, #22c55e, #16a34a);
            color: #fff;
            box-shadow: 0 4px 14px rgba(22, 163, 74, 0.3);
        }
        .btn-download:hover {
            transform: translateY(-2px);
            filter: brightness(1.1);
            box-shadow: 0 6px 20px rgba(22, 163, 74, 0.4);
        }

        /* Nút phụ dạng Outline/Ghost */
        .btn-secondary {
            background: #0f172a;
            border: 1px solid #334155;
            color: #cbd5e1;
        }
        .btn-secondary:hover {
            background: #1e293b;
            border-color: #475569;
            color: #fff;
        }

        .section-label {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #64748b;
            margin: 16px 0 8px 4px;
        }

        /* FOOTER */
        .footer {
            margin-top: 60px;
            padding: 40px 20px;
            text-align: center;
            border-top: 1px solid #1e293b;
            color: #94a3b8;
            font-size: 14px;
        }

        .footer-links {
            margin-top: 12px;
            display: flex;
            justify-content: center;
            gap: 20px;
        }

        .footer-links a { color: #64748b; text-decoration: none; transition: 0.2s; }
        .footer-links a:hover { color: #fff; }

        /* MOBILE OPTIMIZE */
        @media (max-width: 600px) {
            .nav { display: none; }
            .container { padding-top: 80px; }
            .card { padding: 20px; }
            h1 { font-size: 1.25rem; }
        }
    </style>
</head>
<body>

<header class="header">
    <div class="header-inner">
        <a href="/" class="logo">
            <i data-lucide="box"></i> BuilderTV
        </a>
        <nav class="nav">
            <a href="/">Kho file</a>
            <a href="https://atp.hoangtuan.net/<%= file.code %>" target="_blank">Lấy mã kích hoạt</a>
            <a href="https://zalo.me/buildertv" target="_blank">Zalo</a>
        </nav>
    </div>
</header>

<main class="container">
    <a class="back-link" onclick="history.back()">
        <i data-lucide="chevron-left" size="18"></i> Quay lại danh sách
    </a>

    <div class="card">
        <h1><%= file.name %></h1>

        <div class="btn-group">
            <a class="btn btn-download" href="/download/<%= token %>">
                <i data-lucide="download-cloud"></i> TẢI FILE NGAY
            </a>

            <div>
                <div class="section-label">
                    <i data-lucide="play-circle" size="14"></i> Hướng dẫn & Cài đặt
                </div>
                <a class="btn btn-secondary" href="<%= file.video %>" target="_blank">
                    <i data-lucide="youtube" style="color: #ef4444;"></i> Video hướng dẫn sử dụng
                </a>
            </div>

            <div style="margin-top: 8px;">
                <div class="section-label">
                    <i data-lucide="lock" size="14"></i> Bản quyền phần mềm
                </div>
                <a class="btn btn-secondary" href="https://hoangtuan.net/s/225" target="_blank">
                    <i data-lucide="shield-check" style="color: #22c55e;"></i> Video hướng dẫn kích hoạt
                </a>
            </div>
        </div>
    </div>
</main>

<footer class="footer">
    <p>&copy; 2026 <strong>BuilderTV</strong></p>
    <div class="footer-links">
        <a href="https://hoangtuan.net" target="_blank">Trang chủ</a>
        <a href="https://www.youtube.com/@BuilderTV" target="_blank">YouTube</a>
        <a href="https://zalo.me/buildertv" target="_blank">Hỗ trợ</a>
    </div>
</footer>

<script>
    // Khởi tạo các icon Lucide cho giao diện chuyên nghiệp
    lucide.createIcons();
</script>

</body>
</html>