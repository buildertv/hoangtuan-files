<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kho file | BuilderTV</title>
    <meta name="description" content="Kho file BuilderTV - tải nhanh, hướng dẫn đầy đủ">
    <link rel="apple-touch-icon" sizes="180x180" href="https://hoangtuan.net/images/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="https://hoangtuan.net/images/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="https://hoangtuan.net/images/favicon-16x16.png">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>

<style>
    :root {
        --bg-body: #0f172a;
        --bg-header: #020617; /* Đậm hơn để phân biệt */
        --bg-card: #1e293b;
        --bg-card-hover: #273449;
        --primary-green: #22c55e;
        --primary-blue: #3b82f6;
        --text-main: #f8fafc;
        --text-muted: #94a3b8;
        --border: #334155;
    }

    /* RESET & BASE */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
        background: var(--bg-body);
        color: var(--text-main);
        font-family: 'Segoe UI', Roboto, sans-serif;
        line-height: 1.5;
    }

    /* 🔷 FIXED HEADER */
    .header {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        background: var(--bg-header);
        border-bottom: 1px solid var(--border);
        z-index: 1000;
        height: 64px; /* Chiều cao cố định */
        display: flex;
        align-items: center;
    }

    .header-inner {
        max-width: 1100px;
        width: 100%;
        margin: auto;
        display: flex;
        align-items: center;
        padding: 0 16px;
        gap: 20px;
    }

    /* LOGO */
    .logo {
        font-weight: 800;
        font-size: 1.2rem;
        color: #fff;
        cursor: pointer;
        white-space: nowrap;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* 🔍 SEARCH BOX TRONG HEADER */
    .header-search {
        flex-grow: 1;
        max-width: 500px;
        height: 40px;
        display: flex;
        align-items: center;
        gap: 10px;
        background: var(--bg-body);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 0 12px;
        transition: all 0.2s;
    }

    .header-search:focus-within {
        border-color: var(--primary-blue);
        background: var(--bg-card);
        box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);
    }

    .header-search svg, .header-search i {
        width: 18px !important;
        height: 18px !important;
        color: var(--text-muted);
        flex-shrink: 0;
    }

    .header-search input {
        flex: 1;
        height: 100%;
        border: none;
        background: transparent;
        color: white;
        font-size: 0.95rem;
        outline: none;
    }

    /* NAV */
    .nav { display: flex; gap: 20px; }
    .nav a {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        white-space: nowrap;
    }
    .nav a:hover { color: var(--primary-green); }

    /* MAIN CONTENT */
    .container {
        max-width: 1100px;
        margin: auto;
        padding: 100px 16px 40px; /* 100px để không bị header che mất */
    }

    h1 {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    /* FILE LIST GRID */
    #fileList {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 16px;
    }

    /* CARD UI */
    .card {
        background: var(--bg-card);
        padding: 20px;
        border-radius: 16px;
        border: 1px solid var(--border);
        cursor: pointer;
        transition: all 0.25s ease;
        position: relative;
    }

    .card:hover {
        transform: translateY(-4px);
        background: var(--bg-card-hover);
        border-color: var(--primary-green);
    }

    .code {
        font-size: 0.85rem;
        color: var(--text-muted);
        background: rgba(0,0,0,0.2);
        padding: 4px 8px;
        border-radius: 6px;
        display: inline-block;
        margin-top: 8px;
    }

    /* FOOTER */
    .footer {
        margin-top: 60px;
        padding: 40px 20px;
        border-top: 1px solid var(--border);
        text-align: center;
        color: var(--text-muted);
    }

    /* MOBILE RESPONSIVE */
    @media (max-width: 768px) {
        .nav { display: none; }
        .header-inner { gap: 10px; }
        .logo span { display: none; } /* Chỉ hiện icon logo trên mobile nếu cần */
        .container { padding-top: 85px; }
        #fileList { grid-template-columns: 1fr; }
    }
</style>

</head>
<body>

<div class="header">
    <div class="header-inner">
        <div class="logo" onclick="location.href='/'">
            <i data-lucide="package"></i> <span>BuilderTV</span>
        </div>

        <div class="header-search">
            <i data-lucide="search"></i>
            <input type="text" id="searchInput" placeholder="Tìm file nhanh..." autocomplete="off"/>
        </div>

        <div class="nav">
            <a href="https://hoangtuan.net" target="_blank">Trang chủ</a>
            <a href="https://zalo.me/buildertv" target="_blank">Zalo</a>
        </div>
    </div>
</div>

<div class="container">
    <h1><i data-lucide="folder-open" style="color: var(--primary-green);"></i> Kho file</h1>

    <div id="fileList">
        <% files.forEach(f => { %>
        <div class="card" data-name="<%= f.name %>" data-code="<%= f.code %>" onclick="go('<%= f.code %>')">
            <h3><%= f.name %></h3>
            <p class="code">Mã: <%= f.code %></p>
            <div class="card-arrow">
                <i data-lucide="chevron-right" size="20"></i>
            </div>
        </div>
        <% }) %>
    </div>
</div>

<div class="footer">
    <div class="container" style="padding:0">
        <p>&copy; 2026 <strong>BuilderTV</strong>. Phát triển bởi Hoàng Tuấn.</p>
        <div class="footer-links">
            <a href="https://hoangtuan.net" target="_blank">Trang chủ</a>
            <span>|</span>
            <a href="https://www.youtube.com/@BuilderTV" target="_blank">YouTube</a>
            <span>|</span>
            <a href="https://zalo.me/buildertv" target="_blank">Zalo hỗ trợ</a>
        </div>
    </div>
</div>

<script>
    // Khởi tạo icon
    lucide.createIcons();

    // Điều hướng
    function go(code){
        window.location.href = "/" + code;
    }

    // Xử lý tìm kiếm (giữ nguyên logic của bạn nhưng tối ưu tốc độ)
    function removeVietnamese(str) {
        return str.normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .replace(/đ/g, "d")
            .replace(/Đ/g, "D");
    }

    const input = document.getElementById("searchInput");
    const cards = document.querySelectorAll(".card");

    input.addEventListener("input", function() {
        const keyword = removeVietnamese(this.value.toLowerCase().trim());

        cards.forEach(card => {
            const name = removeVietnamese(card.dataset.name.toLowerCase());
            const code = card.dataset.code.toLowerCase();

            if (name.includes(keyword) || code.includes(keyword)) {
                card.style.display = "flex";
            } else {
                card.style.display = "none";
            }
        });
    });
</script>

</body>
</html>
